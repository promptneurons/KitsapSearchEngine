    skos:topConceptOf cec:root ;
    skos:note "Named entities who are natural persons" .

cec:F a skos:Concept ;
    skos:prefLabel "History"@en ;
    skos:notation "F" ;
    skos:inScheme cec:root ;
    skos:topConceptOf cec:root ;
    skos:narrower cec:F1, cec:F2, cec:F3, cec:F4, cec:F5, cec:F6, cec:F7, cec:F8, cec:F9 .

cec:G a skos:Concept ;
    skos:prefLabel "Geography"@en ;
    skos:notation "G" ;
    skos:inScheme cec:root ;
    skos:topConceptOf cec:root ;
    skos:note "Places and regional studies" .

cec:H a skos:Concept ;
    skos:prefLabel "Demotics, Society, Social Science"@en ;
    skos:notation "H" ;
    skos:inScheme cec:root ;
    skos:topConceptOf cec:root ;
    skos:narrower cec:H1, cec:H2, cec:H3, cec:H4, cec:H5 .

cec:J a skos:Concept ;
    skos:prefLabel "Politics, Governance"@en ;
    skos:notation "J" ;
