    skos:broader cec:B534 ;
    skos:inScheme cec:root .

# =============================================================================
# MEC → CEC Crosswalk (for migration)
# =============================================================================

# Current shallow MEC tags mapped to full CEC paths
# This enables automated migration of existing classifications

cec:mec-crosswalk a skos:Collection ;
    rdfs:label "MEC to CEC Crosswalk" ;
    skos:member [
        rdfs:label "philosophy → B" ;
        skos:exactMatch cec:B
    ], [
        rdfs:label "plato → B512.P" ;
        skos:exactMatch cec:B512-P
    ], [
        rdfs:label "aristotle → B512.A" ;
        skos:exactMatch cec:B512-A
    ], [
        rdfs:label "heidegger → B534.H" ;
        skos:exactMatch cec:B534-H
    ], [
        rdfs:label "nietzsche → B534.N" ;
        skos:exactMatch cec:B534-N
    ], [
        rdfs:label "history → F" ;
        skos:exactMatch cec:F
    ], [
        rdfs:label "russia → F7" ;
        skos:exactMatch cec:F7
    ], [
        rdfs:label "economics → H3" ;
        skos:exactMatch cec:H3
    ], [
        rdfs:label "politics → J" ;
        skos:exactMatch cec:J
    ], [
        rdfs:label "christianity → C" ;
        skos:exactMatch cec:C
    ], [
        rdfs:label "orthodox → C" ;
        skos:exactMatch cec:C
    ], [
        rdfs:label "science → L" ;
        skos:exactMatch cec:L
    ], [
        rdfs:label "technology → R" ;
        skos:exactMatch cec:R
    ], [
        rdfs:label "war → U" ;
        skos:exactMatch cec:U
    ], [
        rdfs:label "film → W" ;
        skos:exactMatch cec:W
    ], [
        rdfs:label "music → W" ;
        skos:exactMatch cec:W
    ] .
