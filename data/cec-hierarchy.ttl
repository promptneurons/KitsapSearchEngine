# =============================================================================
# LEVEL 5: Cutter Numbers (Examples for key figures)
# =============================================================================

# Philosophy - Greek
cec:B512-P a skos:Concept ;
    skos:prefLabel "Plato"@en ;
    skos:notation "B512.P" ;
    skos:broader cec:B512 ;
    skos:inScheme cec:root ;
    skos:note "Full path: B > B5 > B51 > B512 > B512.P" .

cec:B512-A a skos:Concept ;
    skos:prefLabel "Aristotle"@en ;
    skos:notation "B512.A" ;
