@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix cec: <http://purl.org/cec/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dct: <http://purl.org/dc/terms/> .

# Cutter Expansive Classification - 5-Level Hierarchy
# Generated: 2026-02-23
# Source: Cutter's Expansive Classification (1882)
# Task: bd-5mc.2

# =============================================================================
# LEVEL 0: Root
# =============================================================================

cec:root a skos:ConceptScheme ;
    rdfs:label "Cutter Expansive Classification" ;
    dct:creator "Charles Ammi Cutter" ;
    dct:date "1882" ;
    skos:note "Transitional between Dewey Decimal and Library of Congress systems" ;
    skos:hasTopConcept cec:A, cec:B, cec:C, cec:D, cec:E, cec:F, cec:G, cec:H,
                       cec:J, cec:K, cec:L, cec:M, cec:N, cec:O, cec:Q, cec:R,
                       cec:U, cec:V, cec:W, cec:X, cec:Y, cec:Z .

# =============================================================================
# LEVEL 1: Main Classes (26)
# =============================================================================

cec:A a skos:Concept ;
    skos:prefLabel "Works of Reference and General"@en ;
    skos:notation "A" ;
    skos:inScheme cec:root ;
    skos:topConceptOf cec:root .

cec:B a skos:Concept ;
    skos:prefLabel "Philosophy, Paedeia, Logic, Religion"@en ;
    skos:notation "B" ;
    skos:inScheme cec:root ;
    skos:topConceptOf cec:root ;
    skos:narrower cec:B1, cec:B2, cec:B3, cec:B4, cec:B5 .

cec:C a skos:Concept ;
    skos:prefLabel "Christianity and Judaism"@en ;
    skos:altLabel "Orthodox Christianity"@en ;
    skos:notation "C" ;
    skos:inScheme cec:root ;
    skos:topConceptOf cec:root ;
    skos:note "Extended for STI to include detailed Orthodox classification" .

cec:D a skos:Concept ;
