    skos:notation "B512" ;
    skos:broader cec:B51 ;
    skos:inScheme cec:root ;
    skos:note "Socrates, Plato, Aristotle" .

cec:B513 a skos:Concept ;
    skos:prefLabel "Roman Philosophy"@en ;
    skos:notation "B513" ;
    skos:broader cec:B51 ;
    skos:inScheme cec:root ;
    skos:note "Stoicism, Epicureanism, Neoplatonism" .

